rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Draft rules for My Hotel Ops. Adjust before production rollout.
    // Next hardening step:
    // 1) Only allow users with an existing staff profile under /hotels/{hotelId}/staff/{request.auth.uid}
    // 2) Add role-based checks for admin/lead/cleaner/maintenance per collection and operation.
    match /hotels/{hotelId} {
      allow read, write: if request.auth != null;

      // Staff profile and role assignments.
      match /staff/{staffId} {
        allow read: if request.auth != null;
        // TODO: Replace with custom claims role checks (admin/lead).
        allow write: if request.auth != null;
      }

      match /roomPlans/{docId} {
        allow read: if request.auth != null;
        // TODO: Restrict updates by role (admin/lead/cleaner/maintenance).
        allow write: if request.auth != null;
      }

      match /tasks/{taskId} {
        allow read: if request.auth != null;
        // TODO: Enforce role based updates for admin, lead, cleaner, maintenance.
        allow write: if request.auth != null;
      }

      match /maintenanceItems/{itemId} {
        allow read: if request.auth != null;
        // TODO: Limit maintenance updates to maintenance/admin/lead.
        allow write: if request.auth != null;
      }

      match /supplyRequests/{requestId} {
        allow read: if request.auth != null;
        // TODO: Validate category and role-specific write permissions.
        allow write: if request.auth != null;
      }

      match /dailyAvailability/{availabilityId} {
        allow read: if request.auth != null;
        // TODO: Allow self-updates, admin overrides.
        allow write: if request.auth != null;
      }
    }
  }
}
