rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function staffDoc(hotelId) {
      return get(/databases/$(database)/documents/hotels/$(hotelId)/staff/$(request.auth.uid));
    }

    function isHotelStaff(hotelId) {
      return signedIn()
        && staffDoc(hotelId).exists()
        && staffDoc(hotelId).data.active != false;
    }

    function isHotelAdmin(hotelId) {
      return isHotelStaff(hotelId) && staffDoc(hotelId).data.role == 'admin';
    }

    match /hotels/{hotelId} {
      allow read: if isHotelStaff(hotelId);
      allow write: if isHotelAdmin(hotelId);

      // Staff profile and role assignments.
      match /staff/{staffId} {
        allow read: if isHotelStaff(hotelId);
        allow write: if isHotelAdmin(hotelId);
      }

      match /roomPlans/{docId} {
        allow read, write: if isHotelStaff(hotelId);
      }

      match /tasks/{taskId} {
        allow read, write: if isHotelStaff(hotelId);
      }

      match /maintenanceItems/{itemId} {
        allow read, write: if isHotelStaff(hotelId);
      }

      match /supplyRequests/{requestId} {
        allow read, write: if isHotelStaff(hotelId);
      }

      match /dailyAvailability/{availabilityId} {
        allow read, write: if isHotelStaff(hotelId);
      }

      // Import workflows are admin-only by policy.
      match /importJobs/{jobId} {
        allow read, write: if isHotelAdmin(hotelId);
      }

      match /importBackups/{backupId} {
        allow read, write: if isHotelAdmin(hotelId);
      }
    }
  }
}
