# Firebase config for Online rezim
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Server-side Previo import endpoint (never expose in frontend)
PREVIO_IMPORT_SECRET=your_strong_random_secret
PREVIO_IMPORT_HOTEL_ID=chill-apartments
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id"}
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Stav import automation (safe defaults)
AUTO_CONFIRM_STAV_IMPORTS=false
AUTO_CONFIRM_STAV_IMPORTS_DRY_RUN=true

# Frontend mode flags (keep aligned with server flags)
VITE_AUTO_CONFIRM_STAV_IMPORTS=false
VITE_AUTO_CONFIRM_STAV_IMPORTS_DRY_RUN=true
